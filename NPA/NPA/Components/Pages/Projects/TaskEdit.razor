@page "/projects/{ProjectId:int}/tasks/{TaskId:int}/edit"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize(Roles = "Admin,ProjectManager")]
@inject ProjectService ProjectSvc
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Edit Task — NPA</PageTitle>

@if (_task is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="page-header">
        <h1><i class="bi bi-pencil"></i> Edit Task</h1>
        <a href="/projects/@ProjectId" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Project</a>
    </div>

    <div class="npa-card" style="max-width:900px;">
        <EditForm Model="_task" OnValidSubmit="HandleSubmit" FormName="editTask" class="npa-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Task Name *</label>
                <InputText @bind-Value="_task.TaskName" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Additional Detail</label>
                <InputTextArea @bind-Value="_task.AdditionalDetail" class="form-control" rows="2" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label">Priority</label>
                    <InputSelect @bind-Value="_task.Priority" class="form-select">
                        @foreach (var p in Enum.GetValues<Priority>())
                        { <option value="@p">@p</option> }
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Status</label>
                    <InputSelect @bind-Value="_task.Status" class="form-select">
                        @foreach (var s in Enum.GetValues<Data.Models.TaskStatus>())
                        { <option value="@s">@s</option> }
                    </InputSelect>
                </div>
                <div class="col-md-3">
                    <label class="form-label">% Complete</label>
                    <InputNumber @bind-Value="_task.PercentComplete" class="form-control" min="0" max="100" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Consultant</label>
                    <InputSelect @bind-Value="_task.ConsultantId" class="form-select">
                        <option value="">— None —</option>
                        @foreach (var u in _users)
                        { <option value="@u.Id">@u.FullName</option> }
                    </InputSelect>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Comment</label>
                <InputTextArea @bind-Value="_task.Comment" class="form-control" rows="3" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Timeline</label>
                    <InputText @bind-Value="_task.Timeline" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Output</label>
                    <InputText @bind-Value="_task.Output" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Completion Date</label>
                    <InputDate @bind-Value="_task.CompletionDate" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
                <button type="button" class="btn btn-outline-danger" @onclick="HandleDelete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public int TaskId { get; set; }

    [SupplyParameterFromForm]
    private ProjectTask? _task { get; set; }

    private List<ApplicationUser> _users = [];

    protected override async Task OnInitializedAsync()
    {
        _task ??= await ProjectSvc.GetTaskByIdAsync(TaskId);
        _users = await UserManager.Users.Where(u => !u.IsDeleted).OrderBy(u => u.FullName).ToListAsync();
    }

    private async Task HandleSubmit()
    {
        if (_task is null) return;
        var authState = await AuthState.GetAuthenticationStateAsync();
        var appUser = await UserManager.FindByNameAsync(authState.User.Identity?.Name ?? "");
        if (appUser is null) return;

        // Update last comment date if comment changed
        if (!string.IsNullOrEmpty(_task.Comment))
            _task.LastCommentDate = DateTime.UtcNow;

        await ProjectSvc.UpdateTaskAsync(_task, appUser.Id, appUser.FullName);
        await ProjectSvc.RecalculateProgressAsync(ProjectId);
        Navigation.NavigateTo($"/projects/{ProjectId}");
    }

    private async Task HandleDelete()
    {
        if (_task is null) return;
        var authState = await AuthState.GetAuthenticationStateAsync();
        var appUser = await UserManager.FindByNameAsync(authState.User.Identity?.Name ?? "");
        if (appUser is null) return;

        await ProjectSvc.DeleteTaskAsync(TaskId, appUser.Id, appUser.FullName);
        await ProjectSvc.RecalculateProgressAsync(ProjectId);
        Navigation.NavigateTo($"/projects/{ProjectId}");
    }
}
