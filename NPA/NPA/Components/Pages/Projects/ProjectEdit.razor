@page "/projects/{Id:int}/edit"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize(Roles = "Admin,ProjectManager")]
@inject ProjectService ProjectSvc
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Edit Project — NPA</PageTitle>

@if (_project is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="page-header">
        <h1><i class="bi bi-pencil"></i> Edit Project</h1>
        <a href="/projects/@Id" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>

    <div class="npa-card" style="max-width:720px;">
        <EditForm Model="_project" OnValidSubmit="HandleSubmit" FormName="editProject" class="npa-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Project Name *</label>
                <InputText @bind-Value="_project.Name" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea @bind-Value="_project.Description" class="form-control" rows="3" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">PO Number</label>
                    <InputText @bind-Value="_project.PONumber" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Customer</label>
                    <InputText @bind-Value="_project.Customer" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Country</label>
                    <InputSelect @bind-Value="_project.Country" class="form-select">
                        <option value="">— Select Country —</option>
                        @foreach (var c in NPA.Data.Countries.All)
                        { <option value="@c">@c</option> }
                    </InputSelect>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <InputSelect @bind-Value="_project.Status" class="form-select">
                        @foreach (var s in Enum.GetValues<ProjectStatus>())
                        { <option value="@s">@s</option> }
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Priority</label>
                    <InputSelect @bind-Value="_project.Priority" class="form-select">
                        @foreach (var p in Enum.GetValues<Priority>())
                        { <option value="@p">@p</option> }
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">% Complete</label>
                    <InputNumber @bind-Value="_project.PercentComplete" class="form-control" min="0" max="100" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <label class="form-label">Start Date</label>
                    <InputDate @bind-Value="_project.StartDate" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">End Date</label>
                    <InputDate @bind-Value="_project.EndDate" class="form-control" />
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
                <button type="button" class="btn btn-outline-danger" @onclick="HandleDelete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    [SupplyParameterFromForm]
    private Project? _project { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _project ??= await ProjectSvc.GetByIdAsync(Id);
    }

    private async Task HandleSubmit()
    {
        if (_project is null) return;
        var authState = await AuthState.GetAuthenticationStateAsync();
        var appUser = await UserManager.FindByNameAsync(authState.User.Identity?.Name ?? "");
        if (appUser is null) return;

        await ProjectSvc.UpdateAsync(_project, appUser.Id, appUser.FullName);
        Navigation.NavigateTo($"/projects/{Id}");
    }

    private async Task HandleDelete()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var appUser = await UserManager.FindByNameAsync(authState.User.Identity?.Name ?? "");
        if (appUser is null) return;

        await ProjectSvc.DeleteAsync(Id, appUser.Id, appUser.FullName);
        Navigation.NavigateTo("/projects");
    }
}
