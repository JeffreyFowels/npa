@page "/admin/users"
@attribute [StreamRendering]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize(Roles = "Admin")]
@inject UserManager<ApplicationUser> UserManager

<PageTitle>Users — NPA Admin</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-people"></i> Users</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="npa-card">
        <div class="table-responsive">
            <table class="npa-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Entra ID</th>
                        <th>Created</th>
                        <th>Last Login</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in _users)
                    {
                        <tr class="@(u.IsDeleted ? "text-muted" : "")">
                            <td class="fw-semibold">@u.FullName</td>
                            <td>@u.Email</td>
                            <td><span class="badge-status @GetRoleBadge(u.Role)">@u.Role</span></td>
                            <td>@(u.IsEntraUser ? "Yes" : "No")</td>
                            <td>@u.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>@(u.LastLoginAt?.ToString("dd MMM yyyy HH:mm") ?? "Never")</td>
                            <td>
                                <a href="/admin/users/@u.Id/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<ApplicationUser> _users = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _users = await UserManager.Users.OrderBy(u => u.FullName).ToListAsync();
        _loading = false;
    }

    private static string GetRoleBadge(AppRole role) => role switch
    {
        AppRole.Admin => "badge-critical",
        AppRole.ProjectManager => "badge-in-progress",
        AppRole.StandardUser => "badge-completed",
        _ => ""
    };
}
