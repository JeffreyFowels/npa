@page "/risks"
@attribute [StreamRendering]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize]
@inject RiskService RiskSvc
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState

<PageTitle>Risks — NPA</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-shield-exclamation"></i> Risks</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (!_risks.Any())
{
    <div class="npa-card text-center py-5">
        <i class="bi bi-shield-check" style="font-size:3rem; color:var(--npa-text-muted);"></i>
        <p class="mt-2 text-muted">No risks found.</p>
    </div>
}
else
{
    <div class="npa-card">
        <div class="table-responsive">
            <table class="npa-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Project</th>
                        <th>Status</th>
                        <th>Likelihood</th>
                        <th>Impact</th>
                        <th>Score</th>
                        <th>Owner</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in _risks)
                    {
                        <tr>
                            <td class="fw-semibold">@r.Title</td>
                            <td><a href="/projects/@r.ProjectId">@r.Project?.Name</a></td>
                            <td><span class="badge-status @GetRiskStatusBadge(r.Status)">@FormatEnum(r.Status)</span></td>
                            <td>@FormatEnum(r.Likelihood)</td>
                            <td>@FormatEnum(r.Impact)</td>
                            <td><span class="badge bg-@(r.RiskScore >= 12 ? "danger" : r.RiskScore >= 6 ? "warning" : "success")">@r.RiskScore</span></td>
                            <td>@(r.Owner?.FullName ?? "—")</td>
                            <td>@r.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <AuthorizeView Roles="Admin,ProjectManager">
                                    <Authorized>
                                        <a href="/risks/@r.Id/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </Authorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Risk> _risks = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _risks = await RiskSvc.GetAllAsync();
        _loading = false;
    }

    private static string GetRiskStatusBadge(RiskStatus s) => s switch
    {
        RiskStatus.Identified => "badge-identified",
        RiskStatus.Assessing => "badge-assessing",
        RiskStatus.Mitigating => "badge-mitigating",
        RiskStatus.Resolved => "badge-resolved",
        RiskStatus.Accepted => "badge-accepted",
        _ => ""
    };

    private static string FormatEnum<T>(T v) where T : Enum =>
        System.Text.RegularExpressions.Regex.Replace(v.ToString(), "(\\B[A-Z])", " $1");
}
