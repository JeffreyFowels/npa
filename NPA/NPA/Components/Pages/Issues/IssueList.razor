@page "/issues"
@attribute [StreamRendering]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize]
@inject IssueService IssueSvc
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState

<PageTitle>Issues — NPA</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-bug"></i> Issues</h1>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (!_issues.Any())
{
    <div class="npa-card text-center py-5">
        <i class="bi bi-check-circle" style="font-size:3rem; color:var(--npa-text-muted);"></i>
        <p class="mt-2 text-muted">No issues found.</p>
    </div>
}
else
{
    <div class="npa-card">
        <div class="table-responsive">
            <table class="npa-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Project</th>
                        <th>Status</th>
                        <th>Severity</th>
                        <th>Priority</th>
                        <th>Assigned To</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in _issues)
                    {
                        <tr>
                            <td class="fw-semibold">@i.Title</td>
                            <td><a href="/projects/@i.ProjectId">@i.Project?.Name</a></td>
                            <td><span class="badge-status @GetIssueStatusBadge(i.Status)">@FormatEnum(i.Status)</span></td>
                            <td><span class="badge-status @GetSeverityBadge(i.Severity)">@i.Severity</span></td>
                            <td><span class="priority-dot @i.Priority.ToString().ToLower()"></span>@i.Priority</td>
                            <td>@(i.AssignedTo?.FullName ?? "Unassigned")</td>
                            <td>@i.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <AuthorizeView Roles="Admin,ProjectManager">
                                    <Authorized>
                                        <a href="/issues/@i.Id/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                    </Authorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private List<Issue> _issues = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _issues = await IssueSvc.GetAllAsync();
        _loading = false;
    }

    private static string GetIssueStatusBadge(IssueStatus s) => s switch
    {
        IssueStatus.Open => "badge-open",
        IssueStatus.InProgress => "badge-in-progress",
        IssueStatus.Resolved => "badge-resolved",
        IssueStatus.Closed => "badge-closed",
        _ => ""
    };

    private static string GetSeverityBadge(IssueSeverity s) => s switch
    {
        IssueSeverity.Low => "badge-low",
        IssueSeverity.Medium => "badge-medium",
        IssueSeverity.High => "badge-high",
        IssueSeverity.Critical => "badge-critical",
        _ => ""
    };

    private static string FormatEnum<T>(T v) where T : Enum =>
        System.Text.RegularExpressions.Regex.Replace(v.ToString(), "(\\B[A-Z])", " $1");
}
