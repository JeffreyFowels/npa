@page "/issues/{Id:int}/edit"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize(Roles = "Admin,ProjectManager")]
@inject IssueService IssueSvc
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation

<PageTitle>Edit Issue — NPA</PageTitle>

@if (_issue is null)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    <div class="page-header">
        <h1><i class="bi bi-pencil"></i> Edit Issue</h1>
        <a href="/projects/@_issue.ProjectId" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to Project</a>
    </div>

    <div class="npa-card" style="max-width:720px;">
        <EditForm Model="_issue" OnValidSubmit="HandleSubmit" FormName="editIssue" class="npa-form">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label class="form-label">Title *</label>
                <InputText @bind-Value="_issue.Title" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea @bind-Value="_issue.Description" class="form-control" rows="3" />
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Status</label>
                    <InputSelect @bind-Value="_issue.Status" class="form-select">
                        @foreach (var s in Enum.GetValues<IssueStatus>())
                        { <option value="@s">@s</option> }
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Severity</label>
                    <InputSelect @bind-Value="_issue.Severity" class="form-select">
                        @foreach (var s in Enum.GetValues<IssueSeverity>())
                        { <option value="@s">@s</option> }
                    </InputSelect>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Priority</label>
                    <InputSelect @bind-Value="_issue.Priority" class="form-select">
                        @foreach (var p in Enum.GetValues<Priority>())
                        { <option value="@p">@p</option> }
                    </InputSelect>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Assign To</label>
                <InputSelect @bind-Value="_issue.AssignedToId" class="form-select">
                    <option value="">— Unassigned —</option>
                    @foreach (var u in _users)
                    {
                        <option value="@u.Id">@u.FullName (@u.Email)</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">Resolution</label>
                <InputTextArea @bind-Value="_issue.Resolution" class="form-control" rows="3" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Save Changes</button>
                <button type="button" class="btn btn-outline-danger" @onclick="HandleDelete"><i class="bi bi-trash"></i> Delete</button>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    [SupplyParameterFromForm]
    private Issue? _issue { get; set; }

    private List<ApplicationUser> _users = [];

    protected override async Task OnInitializedAsync()
    {
        _issue ??= await IssueSvc.GetByIdAsync(Id);
        _users = await UserManager.Users.Where(u => !u.IsDeleted).OrderBy(u => u.FullName).ToListAsync();
    }

    private async Task HandleSubmit()
    {
        if (_issue is null) return;
        var authState = await AuthState.GetAuthenticationStateAsync();
        var appUser = await UserManager.FindByNameAsync(authState.User.Identity?.Name ?? "");
        if (appUser is null) return;

        await IssueSvc.UpdateAsync(_issue, appUser.Id, appUser.FullName);
        Navigation.NavigateTo($"/projects/{_issue.ProjectId}");
    }

    private async Task HandleDelete()
    {
        if (_issue is null) return;
        var authState = await AuthState.GetAuthenticationStateAsync();
        var appUser = await UserManager.FindByNameAsync(authState.User.Identity?.Name ?? "");
        if (appUser is null) return;

        var projectId = _issue.ProjectId;
        await IssueSvc.DeleteAsync(Id, appUser.Id, appUser.FullName);
        Navigation.NavigateTo($"/projects/{projectId}");
    }
}
